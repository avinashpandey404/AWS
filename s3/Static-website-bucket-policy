🧾 ✅ FINAL POLICY (for AWS upload)

{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadAccess",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::nancymishrawebsite/*"
    }
  ]
}

